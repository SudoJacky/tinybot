{
  "runId": "parity-one-tool-then-final",
  "model": "test-model",
  "maxIterations": 3,
  "maxToolResultChars": 1000,
  "messages": [
    {
      "role": "user",
      "content": "hello"
    }
  ],
  "responses": [
    {
      "content": "",
      "stopReason": "tool_calls",
      "toolCalls": [
        {
          "id": "call-1",
          "name": "echo",
          "arguments": {
            "text": "from tool"
          }
        }
      ]
    },
    {
      "content": "tool complete",
      "stopReason": "stop",
      "toolCalls": []
    }
  ],
  "toolResults": {
    "echo": "echo:{text}"
  },
  "expected": {
    "finalContent": "tool complete",
    "stopReason": "final_response",
    "toolsUsed": ["echo"],
    "messageRoles": ["user", "assistant", "tool", "assistant"],
    "checkpoints": ["awaiting_tools", "tools_completed", "final_response"]
  }
}
